# Local runtime/output storage. This holds chat/session DBs and can also hold CLI v1/v2 artifacts.
DESYSFLOW_STORAGE_ROOT=./.desflow

# Chat/session persistence
CHAT_STORE_BACKEND=sqlite
CHAT_DB_PATH=
SESSION_DB_PATH=
DATABASE_URL=
REDIS_URL=redis://localhost:6379/0
CHAT_CACHE_TTL_SECONDS=60

# Active provider: ollama, openai, or anthropic
MODEL_PROVIDER=ollama

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b-cloud
OLLAMA_CRITIC_MODEL=gpt-oss:20b-cloud
OLLAMA_TIMEOUT=120
OLLAMA_NUM_PREDICT=2048

# OpenAI
OPENAI_MODEL=gpt-5.4
OPENAI_CRITIC_MODEL=gpt-5.4
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_CRITIC_MODEL=claude-opus-4-6
ANTHROPIC_API_KEY=

# Optional web search
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

# Critic/reviewer loop controls
CRITIC_MAX_RUNS_PER_SESSION=3
CRITIC_ITERATION_LIMIT=3
CRITIC_PASS_MAX_RISK=45

# Guardrail: set to "true" to enable secret-leak detection on LLM output
LLM_GUARDRAIL=true

# UI dev proxy
VITE_API_PROXY_TARGET=http://localhost:8000
