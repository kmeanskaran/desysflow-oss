#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
Usage:
  ./letsvibedesign              Interactive wizard - pick a run mode
  ./letsvibedesign cli          Run basic CLI design flow
  ./letsvibedesign dev          Start API + UI together (http://localhost:5173)
  ./letsvibedesign api          Start API only (http://localhost:8000/docs)
  ./letsvibedesign ui           Start UI only (http://localhost:5173)
  ./letsvibedesign check        Check model/provider availability
  ./letsvibedesign help         Show this message
EOF
}

ensure_bootstrap() {
  if [ ! -f ".env.example" ] || [ ! -d ".venv" ] || [ ! -d "ui/node_modules" ]; then
    echo "First-time setup required..."
    ./scripts/bootstrap.sh
  fi
}

pick_mode() {
  cat >&2 <<'EOF'
Select start mode:
  1) cli   - basic design flow
  2) dev   - API + UI together
  3) api   - backend API only
  4) ui    - frontend UI only
  5) check - model health check
EOF
  printf "Choice [1-5] (default: 1): " >&2
  read -r raw
  case "${raw:-1}" in
    1|cli) echo "cli" ;;
    2|dev) echo "dev" ;;
    3|api) echo "api" ;;
    4|ui) echo "ui" ;;
    5|check) echo "check" ;;
    *)
      echo "Invalid choice: ${raw}" >&2
      echo "cli"
      ;;
  esac
}

source_env() {
  if [ -f ".env.example" ]; then
    set -a
    . ./.env.example
    set +a
  fi
}

run_mode() {
  local mode="$1"
  case "$mode" in
    cli)
      run_cli_loop
      ;;
    dev)
      ensure_bootstrap
      source_env
      exec ./scripts/dev.sh
      ;;
    api)
      ensure_bootstrap
      source_env
      exec ./scripts/api.sh
      ;;
    ui)
      ensure_bootstrap
      source_env
      exec ./scripts/ui.sh
      ;;
    check)
      ensure_bootstrap
      source_env
      exec uv run python scripts/check_model.py
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown mode: $mode"
      usage
      exit 1
      ;;
  esac
}

run_cli_loop() {
  ensure_bootstrap
  source_env

  echo "Starting CLI design flow."
  echo "After each run:"
  echo "  - /design <prompt> to run with a prompt"
  echo "  - /design to enter a prompt interactively"
  echo "  - /restart to pick mode again"
  echo "  - /bye to exit"

  local should_run=1
  local choice=""
  local next_prompt=""

  run_design() {
    local design_prompt="${1:-}"
    if [ -n "$design_prompt" ]; then
      uv run desysflow design --prompt "$design_prompt"
    else
      uv run desysflow design
    fi
  }

  while true; do
    if [ "$should_run" -eq 1 ]; then
      if ! run_design "$next_prompt"; then
        echo "Design run exited with an error. You can try again, /restart, or /bye."
      fi
      next_prompt=""
    fi

    printf "letsvibe> "
    if ! read -r choice; then
      break
    fi

    case "${choice}" in
      ""|/run|run)
        should_run=1
        ;;
      /design)
        printf "prompt> "
        if read -r next_prompt; then
          should_run=1
        else
          break
        fi
        ;;
      /design\ *)
        next_prompt="${choice#/design }"
        should_run=1
        ;;
      /bye|bye|/exit|exit|quit|/quit)
        echo "Bye."
        break
        ;;
      /restart|restart)
        choice="$(pick_mode)"
        if [ "$choice" = "cli" ]; then
          should_run=1
        else
          run_mode "$choice"
          break
        fi
        ;;
      /help|help)
        echo "Commands:"
        echo "  [Enter|run]         run design again"
        echo "  /design             ask for prompt, then run"
        echo "  /design <prompt>    run with prompt"
        echo "  /restart            show mode picker"
        echo "  /bye                exit"
        should_run=0
        ;;
      /*)
        echo "Unknown input: ${choice}. Use /help, /restart, or /bye."
        should_run=0
        ;;
      *)
        next_prompt="${choice}"
        should_run=1
        ;;
    esac
  done
}

MODE="${1:-}"
if [ -z "$MODE" ]; then
  ensure_bootstrap
  MODE="$(pick_mode)"
fi

run_mode "$MODE"
