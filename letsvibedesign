#!/usr/bin/env bash

set -euo pipefail

INVOKE_CWD="$(pwd)"
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT_DIR"

usage() {
  cat <<'EOF'
Usage:
  letsvibedesign                Run the CLI design flow
  letsvibedesign studio         Start API + UI together (http://localhost:5173)
  letsvibedesign help           Show this message
EOF
}

ensure_bootstrap() {
  if [ ! -f ".env.example" ] || [ ! -d ".venv" ] || [ ! -d "ui/node_modules" ]; then
    echo "First-time setup required..."
    ./scripts/bootstrap.sh
  fi
}

source_env() {
  if [ -f ".env.example" ]; then
    set -a
    . ./.env.example
    set +a
  fi
}

normalize_storage_root() {
  local raw="${DESYSFLOW_STORAGE_ROOT:-}"
  if [ -z "$raw" ]; then
    export DESYSFLOW_STORAGE_ROOT="$INVOKE_CWD/.desysflow"
    return
  fi
  case "$raw" in
    /*|~*) ;;
    *)
      export DESYSFLOW_STORAGE_ROOT="$INVOKE_CWD/$raw"
      ;;
  esac
}

run_mode() {
  local mode="$1"
  case "$mode" in
    ""|cli)
      run_cli_loop
      ;;
    studio|dev)
      ensure_bootstrap
      source_env
      normalize_storage_root
      exec ./scripts/dev.sh
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      echo "Unknown mode: $mode"
      usage
      exit 1
      ;;
  esac
}

run_cli_loop() {
  ensure_bootstrap
  source_env
  normalize_storage_root

  echo "Starting CLI design flow."
  echo "After each run:"
  echo "  - design <prompt> to run with a prompt"
  echo "  - design to enter a prompt interactively"
  echo "  - ls / pwd to inspect your invoke directory"
  echo "  - use letsvibedesign studio from your shell to open the UI"
  echo "  - bye to exit"

  local should_run=1
  local choice=""
  local next_prompt=""

  run_design() {
    local design_prompt="${1:-}"
    if [ -n "$design_prompt" ]; then
      uv run desysflow design --source "$INVOKE_CWD" --prompt "$design_prompt"
    else
      uv run desysflow design --source "$INVOKE_CWD"
    fi
  }

  while true; do
    if [ "$should_run" -eq 1 ]; then
      if ! run_design "$next_prompt"; then
        echo "Design run exited with an error. You can try again, restart, or bye."
      fi
      next_prompt=""
    fi

    printf "letsvibe> "
    if ! read -r choice; then
      break
    fi

    case "${choice}" in
      ""|run)
        should_run=1
        ;;
      design)
        printf "prompt> "
        if read -r next_prompt; then
          should_run=1
        else
          break
        fi
        ;;
      design\ *)
        next_prompt="${choice#design }"
        should_run=1
        ;;
      ls)
        ls -la "$INVOKE_CWD"
        should_run=0
        ;;
      pwd)
        printf '%s\n' "$INVOKE_CWD"
        should_run=0
        ;;
      bye|exit|quit)
        echo "Bye."
        break
        ;;
      help)
        echo "Commands:"
        echo "  [Enter|run]       run design again"
        echo "  design            ask for prompt, then run"
        echo "  design <prompt>   run with prompt"
        echo "  ls                list files in the invoke directory"
        echo "  pwd               show invoke directory path"
        echo "  letsvibedesign studio  start the UI from your shell"
        echo "  bye               exit"
        should_run=0
        ;;
      *)
        next_prompt="${choice}"
        should_run=1
        ;;
    esac
  done
}

MODE="${1:-cli}"

run_mode "$MODE"
